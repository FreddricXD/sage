# Database
DATABASE_URL=postgresql+psycopg2://sage:sage@localhost:5434/sage

# Auth
JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CLIENT_URL=http://localhost:5173

# AI provider selection: ollama | openai | anthropic
AI_PROVIDER=ollama
# Embedding provider: ollama | openai
EMBEDDING_PROVIDER=ollama
EMBEDDING_DIM=768

# Ollama (local, default - no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1
OLLAMA_EMBED_MODEL=nomic-embed-text

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Anthropic (optional - chat only; use ollama/openai for embeddings)
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-3-5-sonnet-latest

# RAG tuning
CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K=5
UPLOAD_DIR=uploads
